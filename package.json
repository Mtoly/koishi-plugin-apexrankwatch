{
  "name": "koishi-plugin-apexrankwatch",
  "description": "Apex Legends rank query and watch plugin for Koishi",
  "version": "1.1.6",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib"
  ],
  "license": "MIT",
  "author": "moeneri",
  "keywords": [
    "apex",
    "apex-legends",
    "chatbot",
    "koishi",
    "plugin",
    "rank",
    "tracker"
  ],
  "scripts": {
    "build": "node ../../../../node_modules/typescript/bin/tsc -b tsconfig.json && node ../../../../node_modules/esbuild/bin/esbuild src/index.ts --bundle --platform=node --format=cjs --target=node18 --outfile=lib/index.js --external:koishi",
    "test": "yarn exec tsx --test test/*.test.ts"
  },
  "peerDependencies": {
    "koishi": "^4.18.7"
  },
  "devDependencies": {
    "esbuild": "^0.23.1",
    "tsx": "^4.16.2",
    "typescript": "^5.6.2",
    "yakumo": "^1.0.0-beta.21"
  }
}
